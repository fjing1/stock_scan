// Dip-in-Uptrend — long entry + mean-reversion exit, derived from backtesting
// sub-components of "Cycle and Stoch" + "寻龙诀 Panel".
//
// ENTRY : Close > SMA200  AND  RSI(14) < 40  AND  Stoch %K(10,EMA4) < 20
// EXIT  : Close >= SMA20  (default; sell back at the mean — best exit in testing).
//         Options: Stoch %K>=70, RSI(2)>=70 (faster), RSI(14)>=50, MA break, time.
//
// Backtested out-of-sample (2019-2026, 30-name daily basket):
//   SMA20 exit ~74% win, PF ~2.2 | %K>=70 ~71% win, PF ~2.0. Sell into STRENGTH;
//   trailing/volatility stops underperform this mean-reversion setup.
// Stops HURT this setup (dips that go deeper are the ones that bounce); the
// >SMA200 filter is the risk control. Entry+exit on close; add costs yourself.

//@version=6
indicator("Dip-in-Uptrend (Cycle+寻龙诀)", shorttitle="DipUptrend", overlay=true)

// ----------------------------- Inputs ----------------------------- //
gTrend = "Trend Filter"
maLen  = input.int(200, "Trend SMA length", minval=1, group=gTrend)

gOS = "Oversold Entry (all enabled must be true)"
useRSI    = input.bool(true,  "Require RSI oversold", group=gOS)
rsiLen    = input.int(14, "RSI length", minval=1, group=gOS)
rsiThresh = input.float(40, "RSI < ", step=1, group=gOS)
useK      = input.bool(true,  "Require Stoch %K oversold", group=gOS)
kLen      = input.int(10, "Stoch %K length", minval=1, group=gOS)
kSmooth   = input.int(4,  "Stoch %K EMA smooth", minval=1, group=gOS)
kThresh   = input.float(20, "Stoch %K < ", step=1, group=gOS)
useCycle  = input.bool(false, "Require Cycle oversold", group=gOS)
cycThresh = input.float(20, "Cycle < ", step=1, group=gOS)

gExit = "Exit Rule"
exitMode = input.string("Close >= SMA (mean revert)", "Exit when",
     options=["Close >= SMA (mean revert)", "Stoch %K >= level", "RSI(2) >= level", "RSI(14) >= level", "Close < Trend SMA", "Time (N bars)"], group=gExit)
exitSMA  = input.int(20, "  Mean-revert SMA length (best in test)", minval=1, group=gExit)
exitK    = input.float(70, "  Stoch %K exit level", step=1, group=gExit)
exitRSI2 = input.float(70, "  RSI(2) exit level", step=1, group=gExit)
exitRSI  = input.float(50, "  RSI(14) exit level", step=1, group=gExit)
exitN    = input.int(10, "  Time exit (bars)", minval=1, group=gExit)

gVis = "Visual"
showShade = input.bool(true, "Shade while in trade", group=gVis)
showTable = input.bool(true, "Show status table", group=gVis)

// ----------------------------- Indicators ----------------------------- //
ma  = ta.sma(close, maLen)
rsi = ta.rsi(close, rsiLen)
rsi2 = ta.rsi(close, 2)
smaExit = ta.sma(close, exitSMA)
rawK   = ta.stoch(close, high, low, kLen)
stochK = ta.ema(rawK, kSmooth)
PDS      = 10
preC     = ta.stoch(close, high, low, PDS)
xPreCalc = ta.ema(preC, 3)
xDSS     = ta.stoch(xPreCalc, xPreCalc, xPreCalc, PDS)
cycle    = ta.ema(0.5 * xDSS + 0.5 * xPreCalc[1], 3)

// ----------------------------- Entry / Exit state machine ----------------------------- //
trendUp  = close > ma
osRSI    = not useRSI   or rsi    < rsiThresh
osK      = not useK     or stochK < kThresh
osCycle  = not useCycle or cycle  < cycThresh
oversold = osRSI and osK and osCycle
entrySignal = trendUp and oversold

var bool  inTrade   = false
var float entryPx   = na
var int   entryBar  = na

held = inTrade ? (bar_index - entryBar) : na
exitCond = switch exitMode
    "Close >= SMA (mean revert)" => close >= smaExit
    "Stoch %K >= level"          => stochK >= exitK
    "RSI(2) >= level"            => rsi2 >= exitRSI2
    "RSI(14) >= level"           => rsi   >= exitRSI
    "Close < Trend SMA"          => close < ma
    "Time (N bars)"              => held >= exitN
    => close >= smaExit

sell = inTrade and exitCond
buy  = (not inTrade) and entrySignal      // computed before state update -> no same-bar re-entry
if sell
    inTrade := false
if buy
    inTrade := true
    entryPx := close
    entryBar := bar_index

tradeRet = inTrade or sell ? (close / entryPx - 1.0) * 100.0 : na

// ----------------------------- Plots ----------------------------- //
plot(ma, "Trend SMA", color = trendUp ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=2)
bgcolor(showShade and (inTrade or sell) ? color.new(color.green, 90) : na, title="In trade")
plotshape(buy,  "BUY",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.green, 0), size=size.small, text="BUY",  textcolor=color.white)
plotshape(sell, "SELL", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),   size=size.small, text="SELL", textcolor=color.white)

alertcondition(buy,  title="Dip-in-Uptrend BUY",  message="BUY {{ticker}} ({{interval}}) at {{close}}")
alertcondition(sell, title="Dip-in-Uptrend SELL", message="SELL {{ticker}} ({{interval}}) at {{close}}")

// ----------------------------- Status table ----------------------------- //
f_col(ok) => ok ? color.lime : color.gray
var table tb = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 30), frame_color=color.new(color.white, 0), frame_width=1, border_color=color.new(color.white, 70), border_width=1)
if barstate.islast and showTable
    table.cell(tb, 0, 0, "Dip-in-Uptrend", text_color=color.white)
    table.cell(tb, 1, 0, inTrade ? ("● in trade " + str.tostring(tradeRet, "#.#") + "%") : "— flat", text_color = inTrade ? color.lime : color.gray)
    table.cell(tb, 0, 1, "Close > SMA" + str.tostring(maLen), text_color=color.white)
    table.cell(tb, 1, 1, trendUp ? "yes" : "no", text_color=f_col(trendUp))
    table.cell(tb, 0, 2, "RSI(" + str.tostring(rsiLen) + ")", text_color=color.white)
    table.cell(tb, 1, 2, str.tostring(rsi, "#.#"), text_color=f_col(osRSI))
    table.cell(tb, 0, 3, "Stoch %K", text_color=color.white)
    table.cell(tb, 1, 3, str.tostring(stochK, "#.#"), text_color=f_col(osK))
    table.cell(tb, 0, 4, "Cycle", text_color=color.white)
    table.cell(tb, 1, 4, str.tostring(cycle, "#.#"), text_color = useCycle ? f_col(osCycle) : color.gray)
    table.cell(tb, 0, 5, "Exit: " + exitMode, text_color=color.white)
    table.cell(tb, 1, 5, exitCond ? "ready" : "no", text_color=f_col(exitCond))
