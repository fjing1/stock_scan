// Dip-in-Uptrend STRATEGY — runnable in TradingView's Strategy Tester.
// Same entry/exit as the indicator; lets you see win rate / profit factor / P&L.
//
// ENTRY : Close > SMA200  AND  RSI(14) < 40  AND  Stoch %K(10,EMA4) < 20
// EXIT  : Close >= SMA20  (default; sell back at the mean — best exit in testing).
//         Options: Stoch %K>=70, RSI(2)>=70, RSI(14)>=50, SMA200 break, time.
//
// Out-of-sample reference (2019-2026, 30-name daily basket): SMA20 exit ~74% win,
// PF ~2.2; %K>=70 ~71% win, PF ~2.0. Strategy Tester runs ONE symbol at a time;
// pooled multi-name results are smoother. Tight/trailing stops degrade this setup.

//@version=6
strategy("Dip-in-Uptrend Strategy", shorttitle="DipUptrend ST", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     initial_capital=10000, commission_type=strategy.commission.percent,
     commission_value=0.03, slippage=2, calc_on_every_tick=false,
     pyramiding=0, process_orders_on_close=true)

// ----------------------------- Inputs ----------------------------- //
maLen     = input.int(200, "Trend SMA length", minval=1, group="Trend Filter")
useRSI    = input.bool(true,  "Require RSI oversold", group="Oversold Entry")
rsiLen    = input.int(14, "RSI length", minval=1, group="Oversold Entry")
rsiThresh = input.float(40, "RSI < ", step=1, group="Oversold Entry")
useK      = input.bool(true,  "Require Stoch %K oversold", group="Oversold Entry")
kLen      = input.int(10, "Stoch %K length", minval=1, group="Oversold Entry")
kSmooth   = input.int(4,  "Stoch %K EMA smooth", minval=1, group="Oversold Entry")
kThresh   = input.float(20, "Stoch %K < ", step=1, group="Oversold Entry")
useCycle  = input.bool(false, "Require Cycle oversold", group="Oversold Entry")
cycThresh = input.float(20, "Cycle < ", step=1, group="Oversold Entry")

exitMode = input.string("Close >= SMA (mean revert)", "Exit when",
     options=["Close >= SMA (mean revert)", "Stoch %K >= level", "RSI(2) >= level", "RSI(14) >= level", "Close < Trend SMA", "Time (N bars)"], group="Exit Rule")
exitSMA  = input.int(20, "  Mean-revert SMA length (best in test)", minval=1, group="Exit Rule")
exitK    = input.float(70, "  Stoch %K exit level", step=1, group="Exit Rule")
exitRSI2 = input.float(70, "  RSI(2) exit level", step=1, group="Exit Rule")
exitRSI  = input.float(50, "  RSI(14) exit level", step=1, group="Exit Rule")
exitN    = input.int(10, "  Time exit (bars)", minval=1, group="Exit Rule")
useDisaster = input.bool(false, "Add wide disaster stop", group="Exit Rule")
disasterPct = input.float(20, "  Disaster stop %", step=1, group="Exit Rule")

dateFrom = input.time(timestamp("2005-01-01"), "Backtest from", group="Window")

// ----------------------------- Indicators ----------------------------- //
ma  = ta.sma(close, maLen)
rsi = ta.rsi(close, rsiLen)
rsi2 = ta.rsi(close, 2)
smaExit = ta.sma(close, exitSMA)
rawK   = ta.stoch(close, high, low, kLen)
stochK = ta.ema(rawK, kSmooth)
PDS      = 10
preC     = ta.stoch(close, high, low, PDS)
xPreCalc = ta.ema(preC, 3)
xDSS     = ta.stoch(xPreCalc, xPreCalc, xPreCalc, PDS)
cycle    = ta.ema(0.5 * xDSS + 0.5 * xPreCalc[1], 3)

// ----------------------------- Logic ----------------------------- //
trendUp  = close > ma
osRSI    = not useRSI   or rsi    < rsiThresh
osK      = not useK     or stochK < kThresh
osCycle  = not useCycle or cycle  < cycThresh
entrySignal = trendUp and osRSI and osK and osCycle

held = strategy.position_size > 0 ? (bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)) : na
exitCond = switch exitMode
    "Close >= SMA (mean revert)" => close >= smaExit
    "Stoch %K >= level"          => stochK >= exitK
    "RSI(2) >= level"            => rsi2 >= exitRSI2
    "RSI(14) >= level"           => rsi   >= exitRSI
    "Close < Trend SMA"          => close < ma
    "Time (N bars)"              => held >= exitN
    => close >= smaExit

inWindow = time >= dateFrom

if inWindow and entrySignal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

if strategy.position_size > 0
    if exitCond
        strategy.close("Long", comment="exit")
    else if useDisaster
        strategy.exit("Disaster", "Long", stop=strategy.position_avg_price * (1 - disasterPct / 100.0))

plot(ma, "Trend SMA", color=color.new(color.gray, 0), linewidth=1)
