// Dip-in-Uptrend STRATEGY — runnable in TradingView's Strategy Tester.
// Same entry/exit as the indicator; lets you see win rate / profit factor / P&L.
// Upgraded with research #22 (trend filter) + #19/#20 (PEAD) + #24 (regime-switch COMBO), RESEARCH.md.
//
// TWO modes (input "Strategy mode"):
//  • DIP-BUY IN UPTREND (#4-22): SMA50>SMA200 AND RSI(14)<40 AND Stoch %K<20 -> buy; exit Close>=SMA20.
//      Cash in downtrends. OOS 2019-26 (30-name basket): ~74% win, PF ~2.2.
//  • COMBO regime-switch (#24): HOLD the trend when above the 200-MA (Faber, N-day confirm);
//      when BELOW, trade short mean-reversion bounces (RSI2<10 + optional IBS<0.2, exit first
//      up-close / 10d) instead of sitting in cash. Beats buy-&-hold over a FULL cycle on the INDEX:
//      SPY 2000-26: CAGR 6.4% / Sharpe 0.50 / MaxDD -29% vs B&H 6.4% / 0.42 / -56%.
//      QQQ: 9.8% / 0.56 / -56% vs 8.2% / 0.43 / -83%. Edge = crash-protection + bear-bounce harvest.
//
// CRITICAL (#24): the COMBO beats buy-&-hold ON THE BROAD INDEX (SPY/QQQ), which actually crashes
// in bears — NOT on a survivor large-cap stock basket (there B&H wins; survivorship = no bear pain).
// Run COMBO on SPY/QQQ. MR best practice (Connors/Alvarez/Faber/Pagonidis): RSI2 oversold + IBS<0.2,
// first-up-close exit (best per Alvarez), MR only in the right regime; stops/trailing HURT MR.
// Short-term reversal has DECAYED post-2010 — treat the bear sleeve as weaker going forward.
// Strategy Tester runs ONE symbol at a time. Entry/exit on close; earnings/PEAD need a DAILY chart.

//@version=6
strategy("Dip-in-Uptrend Strategy", shorttitle="DipUptrend ST", overlay=true,
     default_qty_type=strategy.percent_of_equity, default_qty_value=100,
     initial_capital=10000, commission_type=strategy.commission.percent,
     commission_value=0.03, slippage=2, calc_on_every_tick=false,
     pyramiding=0, process_orders_on_close=true)

// ----------------------------- Inputs ----------------------------- //
gMode      = "Strategy mode"
strategyMode = input.string("Dip-buy in uptrend (#4-22)", "Strategy mode",
     options=["Dip-buy in uptrend (#4-22)", "COMBO: hold uptrend + MR-bounce downtrend (#24)"], group=gMode)

gTrend    = "Trend Filter (#22)"
trendMode = input.string("Regime: SMA50>SMA200 (#22)", "Trend filter",
     options=["Regime: SMA50>SMA200 (#22)", "Legacy: Close>SMA200"], group=gTrend)
fastLen   = input.int(50,  "Regime fast SMA", minval=1, group=gTrend)
slowLen   = input.int(200, "Regime slow SMA / legacy trend SMA", minval=1, group=gTrend)
hiLen     = input.int(85,  "Hi-conviction SMA", minval=1, group=gTrend)
reqHiConv = input.bool(false, "Require hi-conv (Close>SMA85) to enter", group=gTrend)
confirmBars = input.int(3, "Regime confirm bars (Faber, #24 COMBO hold)", minval=1, group=gTrend)

gOS = "Oversold Entry"
useRSI    = input.bool(true,  "Require RSI oversold", group=gOS)
rsiLen    = input.int(14, "RSI length", minval=1, group=gOS)
rsiThresh = input.float(40, "RSI < ", step=1, group=gOS)
useK      = input.bool(true,  "Require Stoch %K oversold", group=gOS)
kLen      = input.int(10, "Stoch %K length", minval=1, group=gOS)
kSmooth   = input.int(4,  "Stoch %K EMA smooth", minval=1, group=gOS)
kThresh   = input.float(20, "Stoch %K < ", step=1, group=gOS)
useCycle  = input.bool(false, "Require Cycle oversold", group=gOS)
cycThresh = input.float(20, "Cycle < ", step=1, group=gOS)
useIBS    = input.bool(false, "Require IBS < (MR best-practice, #24)", group=gOS)
ibsThresh = input.float(0.2, "IBS < ", step=0.05, minval=0, maxval=1, group=gOS)
bearRsi   = input.float(10, "COMBO bear-bounce: RSI(2) < (#24)", step=1, group=gOS)

gExit = "Exit Rule"
exitMode = input.string("Close >= SMA (mean revert)", "Exit when (dip-buy mode)",
     options=["Close >= SMA (mean revert)", "First up-close (#24 best)", "Stoch %K >= level", "RSI(2) >= level", "RSI(14) >= level", "Close < Trend SMA", "Time (N bars)"], group=gExit)
exitSMA  = input.int(20, "  Mean-revert SMA length (best in test)", minval=1, group=gExit)
exitK    = input.float(70, "  Stoch %K exit level", step=1, group=gExit)
exitRSI2 = input.float(70, "  RSI(2) exit level", step=1, group=gExit)
exitRSI  = input.float(50, "  RSI(14) exit level", step=1, group=gExit)
exitN    = input.int(10, "  Time exit / COMBO bear-bounce max hold (bars)", minval=1, group=gExit)
useDisaster = input.bool(false, "Add wide disaster stop", group=gExit)
disasterPct = input.float(20, "  Disaster stop %", step=1, group=gExit)

gPead      = "Earnings / PEAD (#19/#20)"
reqPeadBeat = input.bool(false, "Require recent earnings BEAT to enter", group=gPead)
peadWin     = input.int(63, "  In-play window (bars since report)", minval=1, group=gPead)

dateFrom = input.time(timestamp("2005-01-01"), "Backtest from", group="Window")

// ----------------------------- Indicators ----------------------------- //
maFast = ta.sma(close, fastLen)
maSlow = ta.sma(close, slowLen)
maHi   = ta.sma(close, hiLen)
rsi  = ta.rsi(close, rsiLen)
rsi2 = ta.rsi(close, 2)
smaExit = ta.sma(close, exitSMA)
rawK   = ta.stoch(close, high, low, kLen)
stochK = ta.ema(rawK, kSmooth)
PDS      = 10
preC     = ta.stoch(close, high, low, PDS)
xPreCalc = ta.ema(preC, 3)
xDSS     = ta.stoch(xPreCalc, xPreCalc, xPreCalc, PDS)
cycle    = ta.ema(0.5 * xDSS + 0.5 * xPreCalc[1], 3)
ibs      = (high - low) != 0 ? (close - low) / (high - low) : 0.5
firstUpClose = close > close[1]

// ----------------------------- Earnings / PEAD (#19/#20) ----------------------------- //
epsAct = request.earnings(syminfo.tickerid, earnings.actual,   barmerge.gaps_on, ignore_invalid_symbol=true)
epsEst = request.earnings(syminfo.tickerid, earnings.estimate, barmerge.gaps_on, ignore_invalid_symbol=true)
var float lastSurp  = na
var int   lastErnBar = na
if not na(epsAct)
    lastErnBar := bar_index
    lastSurp := (not na(epsEst) and epsEst != 0) ? (epsAct - epsEst) / math.abs(epsEst) * 100.0 : na
barsSinceErn = na(lastErnBar) ? na : bar_index - lastErnBar
peadBeat = not na(barsSinceErn) and barsSinceErn <= peadWin and not na(lastSurp) and lastSurp > 0

// ----------------------------- Regime ----------------------------- //
legacyTrend = trendMode == "Legacy: Close>SMA200"
trendUpRaw  = legacyTrend ? close > maSlow : maFast > maSlow
// Faber-style: require `confirmBars` consecutive up-regime closes (cuts whipsaw, #24)
regimeUp = trendUpRaw and math.sum(trendUpRaw ? 1.0 : 0.0, confirmBars) == confirmBars
hiConv   = close > maHi
combo    = strategyMode == "COMBO: hold uptrend + MR-bounce downtrend (#24)"

// ----------------------------- Oversold gates ----------------------------- //
osRSI    = not useRSI   or rsi    < rsiThresh
osK      = not useK     or stochK < kThresh
osCycle  = not useCycle or cycle  < cycThresh
osIBS    = not useIBS   or ibs    < ibsThresh

inWindow = time >= dateFrom

// ----------------------------- Dip-buy mode exit ----------------------------- //
held = strategy.position_size > 0 ? (bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)) : na
dipExit = switch exitMode
    "Close >= SMA (mean revert)" => close >= smaExit
    "First up-close (#24 best)"  => firstUpClose
    "Stoch %K >= level"          => stochK >= exitK
    "RSI(2) >= level"            => rsi2 >= exitRSI2
    "RSI(14) >= level"           => rsi   >= exitRSI
    "Close < Trend SMA"          => close < maSlow
    "Time (N bars)"              => held >= exitN
    => close >= smaExit

// ----------------------------- Logic ----------------------------- //
var bool mrTrade = false   // COMBO: true if current position is a bear mean-reversion bounce

if combo
    // ---- COMBO regime-switch (#24): hold the trend up-regime; MR-bounce the down-regime ----
    bearBounce = (not trendUpRaw) and rsi2 < bearRsi and osIBS
    if inWindow and strategy.position_size == 0
        if regimeUp
            strategy.entry("Long", strategy.long, comment="hold")
            mrTrade := false
        else if bearBounce
            strategy.entry("Long", strategy.long, comment="mr-bounce")
            mrTrade := true
    else if strategy.position_size > 0
        if regimeUp
            mrTrade := false                       // in an uptrend -> treat as a trend-hold; keep holding
            if useDisaster
                strategy.exit("Disaster", "Long", stop=strategy.position_avg_price * (1 - disasterPct / 100.0))
        else
            if mrTrade
                heldM = bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)
                if firstUpClose or heldM >= exitN
                    strategy.close("Long", comment="mr-exit")
            else
                strategy.close("Long", comment="regime-exit")   // trend broke -> step aside
else
    // ---- Original dip-buy-in-uptrend (#4-22) ----
    entrySignal = trendUpRaw and osRSI and osK and osCycle and osIBS and (not reqHiConv or hiConv) and (not reqPeadBeat or peadBeat)
    if inWindow and entrySignal and strategy.position_size == 0
        strategy.entry("Long", strategy.long)
    if strategy.position_size > 0
        if dipExit
            strategy.close("Long", comment="exit")
        else if useDisaster
            strategy.exit("Disaster", "Long", stop=strategy.position_avg_price * (1 - disasterPct / 100.0))

// ----------------------------- Plots ----------------------------- //
plot(maSlow, "Slow SMA", color=color.new(color.gray, 0), linewidth=1)
plot(maFast, "Fast SMA", color = maFast > maSlow ? color.new(color.green, 0) : color.new(color.red, 0), linewidth=1)
// COMBO regime backdrop: green = trend-hold zone, red = MR-bounce (downtrend) zone
bgcolor(combo ? (regimeUp ? color.new(color.green, 90) : color.new(color.red, 92)) : na, title="COMBO regime")
